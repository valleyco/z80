  "ix_iy_overrides": {
    "DD": {
      "name": "IX override",
      "effect": "HL becomes IX; (HL) becomes (IX + displacement)"
    },
    "FD": {
      "name": "IY override",
      "effect": "HL becomes IY; (HL) becomes (IY + displacement)"
    },
    "undocumented": {
      "description": "Every opcode that manipulates HL is equally valid for the 8-bit halves of IX (IXH, IXL) and IY (IYH, IYL) when preceded by DD or FD, with exceptions for instructions using both HL and IX/IY in the same operation (e.g. LD H,(IX+d))",
      "example": "DD 26 n encodes LD IXH,n instead of LD H,n"
    }
  },
