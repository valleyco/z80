    {
      "id": "interrupt_acknowledge",
      "name": "Interrupt Acknowledge",
      "aliases": [
        "INT ACK",
        "M1 interrupt cycle"
      ],
      "default_t_states": 7,
      "bus_transaction": "interrupt_vector_read",
      "automatic_wait_states": 2,
      "purpose": "Acknowledge maskable interrupt; interrupting device may place 8-bit vector on data bus (mode 2) or CPU fetches restart vector.",
      "notes": [
        "INT is sampled on rising edge of the last T-state of an instruction.",
        "Uses M1 together with IORQ (not MREQ) to distinguish from opcode fetch.",
        "Two automatic wait states support daisy-chain priority (e.g. Z80 PIO/CTC/SIO)."
      ],
