                "M1": "inactive",
                "MREQ": "active",
                "IORQ": "inactive",
                "RD": "active",
                "WR": "inactive",
                "RFSH": "inactive"
              }
            },
            {
              "phase": "T2\u2193",
              "address_bus": "target address",
              "data_bus": "byte stable",
              "cpu_action": "WAIT sampled; CPU samples data on rising edge of T3.",
              "signals": {
                "M1": "inactive",
                "MREQ": "active",
                "IORQ": "inactive",
                "RD": "active",
                "WR": "inactive",
                "RFSH": "inactive"
              }
            }
          ]
        },
        {
          "t": 3,
          "half_cycles": [
            {
              "phase": "T3\u2191",
              "address_bus": "target address",
              "data_bus": "byte latched internally",
              "cpu_action": "Complete read; load byte into destination register or internal latch.",
              "signals": {
                "M1": "inactive",
                "MREQ": "active",
                "IORQ": "inactive",
                "RD": "active",
                "WR": "inactive",
                "RFSH": "inactive"
              }
            },
            {
              "phase": "T3\u2193",
