  "cycle_types": [
    {
      "id": "opcode_fetch",
      "name": "Opcode Fetch",
      "aliases": [
        "M1",
        "Op code fetch",
        "Instruction fetch"
      ],
      "default_t_states": 4,
      "bus_phases": [
        {
          "during": "T1-T2",
          "bus_transaction": "opcode_fetch_read"
        },
        {
          "during": "T3-T4",
          "bus_transaction": "refresh"
        }
      ],
      "also_performs": "DRAM refresh in T3\u2013T4",
      "wait_sampled_at": "second half of T2",
      "purpose": "Fetch instruction byte from memory at PC; increment PC; latch byte into IR.",
      "t_states": [
        {
          "t": 1,
          "half_cycles": [
            {
              "phase": "T1\u2191",
              "address_bus": "PC (16-bit program address)",
              "data_bus": "high_impedance (previous value may still appear)",
              "cpu_action": "Drive PC onto address bus; assert M1.",
              "signals": {
                "M1": "active",
                "MREQ": "inactive",
                "IORQ": "inactive",
                "RD": "inactive",
                "WR": "inactive",
                "RFSH": "inactive"
              }
            },
            {
              "phase": "T1\u2193",
              "address_bus": "PC",
              "data_bus": "high_impedance",
              "cpu_action": "Assert MREQ and RD; begin memory read; PC incremented.",
              "signals": {
                "M1": "active",
                "MREQ": "active",
                "IORQ": "inactive",
                "RD": "active",
                "WR": "inactive",
                "RFSH": "inactive"
              }
            }
          ]
        },
        {
          "t": 2,
          "half_cycles": [
            {
              "phase": "T2\u2191",
              "address_bus": "PC (still driven during read setup)",
              "data_bus": "memory drives fetched byte",
              "cpu_action": "Memory places opcode byte on data bus.",
              "signals": {
                "M1": "active",
                "MREQ": "active",
                "IORQ": "inactive",
                "RD": "active",
                "WR": "inactive",
                "RFSH": "inactive"
              }
            },
            {
              "phase": "T2\u2193",
              "address_bus": "PC",
              "data_bus": "fetched byte stable",
              "cpu_action": "WAIT sampled here; latch opcode into IR at end of read phase.",
              "signals": {
                "M1": "active",
                "MREQ": "active",
                "IORQ": "inactive",
                "RD": "active",
                "WR": "inactive",
                "RFSH": "inactive"
              }
            }
          ]
        },
        {
          "t": 3,
          "half_cycles": [
            {
              "phase": "T3\u2191",
              "address_bus": "{I[7:0], R[7:0]} refresh address (16-bit)",
              "data_bus": "high_impedance",
              "cpu_action": "End opcode read; begin refresh: drive I:R on address bus; assert RFSH.",
              "signals": {
                "M1": "inactive",
                "MREQ": "inactive",
                "IORQ": "inactive",
                "RD": "inactive",
                "WR": "inactive",
                "RFSH": "active"
              }
            },
            {
              "phase": "T3\u2193",
              "address_bus": "{I, R}",
              "cpu_action": "Assert MREQ for refresh read; increment R register (lower 7 bits).",
              "signals": {
                "M1": "inactive",
                "MREQ": "active",
                "IORQ": "inactive",
                "RD": "inactive",
                "WR": "inactive",
                "RFSH": "active"
              }
            }
          ]
        },
        {
          "t": 4,
          "half_cycles": [
            {
              "phase": "T4\u2191",
              "address_bus": "{I, R}",
              "cpu_action": "DRAM refresh read \u2014 all dynamic memories should refresh.",
              "signals": {
                "M1": "inactive",
                "MREQ": "active",
                "IORQ": "inactive",
                "RD": "inactive",
                "WR": "inactive",
                "RFSH": "active"
              }
            },
            {
              "phase": "T4\u2193",
              "address_bus": "lower byte often cleared (implementation detail)",
              "cpu_action": "Complete refresh; CPU internally decodes/executes instruction.",
              "signals": {
                "M1": "inactive",
                "MREQ": "inactive",
                "IORQ": "inactive",
                "RD": "inactive",
                "WR": "inactive",
                "RFSH": "active"
              }
            }
          ]
        }
      ]
    },
