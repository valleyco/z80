{
  "source": [
    "https://bitsavers.org/components/zilog/z80/03-0027-02_Z80_CPU_Product_Specification_Mar78.pdf",
    "https://floooh.github.io/2021/12/06/z80-instruction-timing.html",
    "https://en.wikipedia.org/wiki/Z80_instruction_set"
  ],
  "title": "Z80 machine cycle types",
  "summary": {
    "description": "A machine cycle (M-cycle) is a group of T-states (clock cycles) that perform one bus transaction or internal operation. Instructions are built from one or more M-cycles.",
    "t_state": "One full clock period (\u03c6 cycle). Each T-state has two half-cycles (rising and falling clock edges).",
    "default_lengths": {
      "opcode_fetch": 4,
      "memory_read": 3,
      "memory_write": 3,
      "io_read": 4,
      "io_write": 4,
      "interrupt_acknowledge": 7,
      "internal": 1,
      "halt_fetch": 4
    },
    "notes": [
      "WAIT can extend any memory or I/O cycle by inserting Tw wait states.",
      "I/O cycles include one automatically inserted wait state (Tw*) for port decode.",
      "Interrupt acknowledge includes two automatically inserted wait states (Tw*).",
      "Every M1 cycle (including prefix fetches) performs dynamic RAM refresh during T3\u2013T4."
    ]
  },
  "signal_conventions": {
    "active_level": "All control signals listed below are active LOW unless noted.",
    "tri_state": [
      "MREQ",
      "IORQ",
      "RD",
      "WR",
      "address_bus",
      "data_bus"
    ],
    "bus_signals": {
      "M1": "Machine cycle one \u2014 opcode fetch or interrupt acknowledge.",
      "MREQ": "Memory request \u2014 address bus holds a valid memory address.",
      "IORQ": "I/O request \u2014 lower address bus (A7\u2013A0) holds a valid I/O address.",
      "RD": "Read \u2014 CPU requests data from memory or I/O.",
      "WR": "Write \u2014 CPU drives stable data for memory or I/O write.",
      "RFSH": "Refresh \u2014 lower 7 address bits (A6\u2013A0) hold a DRAM refresh address.",
      "WAIT": "Input \u2014 when active, CPU inserts wait states until released.",
      "HALT": "Output \u2014 CPU has executed HALT and awaits interrupt.",
      "BUSAK": "Output \u2014 CPU has released the bus to an external master (DMA)."
    },
    "signal_state": {
      "active": "Signal asserted (electrically low for control outputs)",
      "inactive": "Signal deasserted (electrically high)",
      "dont_care": "Signal state is not relevant for decoding this transaction"
    },
    "decode_signals": [
      "M1",
      "MREQ",
      "IORQ",
      "RD",
      "WR",
      "RFSH"
    ],
    "schema_rules": {
      "bus_decoding": "Canonical definition of each bus transaction. Every entry lists all decode_signals with explicit active or inactive.",
      "cycle_types.bus_transaction": "For single-transaction cycles, names a bus_decoding key. Resolve the full signal map from bus_decoding \u2014 never infer inactive from omission elsewhere.",
      "cycle_types.bus_phases": "For multi-transaction cycles (e.g. opcode fetch), lists which bus_decoding key applies during which T-states.",
      "half_cycles.signals": "Each half-cycle must include a signals object with all six decode_signals set to active or inactive. Omitted signals are invalid \u2014 absence does not mean inactive.",
      "half_cycles.status_outputs": "Optional fields such as HALT are CPU status outputs, not part of decode_signals or the signals object."
    },
    "bus_decoding": {
      "opcode_fetch_read": {
